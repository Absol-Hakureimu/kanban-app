# URL de conexión a PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/kanban_db"

# Puerto del servidor
PORT=4000

# URL del frontend (para CORS y Socket.io)
CLIENT_URL="http://localhost:5173"

# Secretos para firmar tokens JWT (cambia estos valores en producción)
JWT_ACCESS_SECRET="cambia_este_secreto_de_acceso"
JWT_REFRESH_SECRET="cambia_este_secreto_de_refresh"

NODE_ENV=development
